# Anthropic API（必須）
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenRouteService API（ルート生成に必要、無料枠あり）
# https://openrouteservice.org/dev/#/signup で取得
ORS_API_KEY=xxxxx

# OpenMeteo API はキー不要

# Strava API（Strava連携を使う場合に必要）
# https://www.strava.com/settings/api で取得
STRAVA_CLIENT_ID=your_strava_client_id_here
STRAVA_CLIENT_SECRET=your_strava_client_secret_here
STRAVA_REDIRECT_URI=http://localhost:5173/strava/callback
